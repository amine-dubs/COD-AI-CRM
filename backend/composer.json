{
    "name": "codcrm/api",
    "description": "COD CRM — Multi-Tenant eCommerce CRM REST API",
    "type": "project",
    "license": "proprietary",
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^6.11",
        "vlucas/phpdotenv": "^5.6"
    },
    "autoload": {
        "psr-4": {
            "App\\": "src/"
        }
    },
    "scripts": {
        "start": "php -S localhost:8000 -t public",
        "migrate": "php database/migrate.php",
        "seed": "php database/seed.php"
    },
    "config": {
        "optimize-autoloader": true,
        "sort-packages": true,
        "audit": {
            "abandoned": "report",
            "block-insecure": false
        }
    }
}
